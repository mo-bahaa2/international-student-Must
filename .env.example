# Supabase configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional alternative for projects using publishable API keys
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Optional dashboard shortcut used in header
VITE_SUPABASE_DASHBOARD_URL=https://supabase.com/dashboard/project/your-project-ref

# Optional table overrides (defaults are coded in src/services/cmsApi.ts)
# VITE_SUPABASE_STAFF_TABLE=staff
# VITE_SUPABASE_NEWS_TABLE=news
# VITE_SUPABASE_EVENTS_TABLE=events
# VITE_SUPABASE_STUDY_PLANS_TABLE=study_plans
# VITE_SUPABASE_SCHEDULES_TABLE=schedules
# VITE_SUPABASE_CALENDARS_TABLE=calendars
# VITE_SUPABASE_ACTIVITIES_TABLE=activities
# VITE_SUPABASE_ACTIVITIES_IMAGES_BUCKET=activity-images
# VITE_SUPABASE_GALLERY_TABLE=photo_gallery
# VITE_SUPABASE_STUDENT_RESOURCES_TABLE=student_resources
# VITE_SUPABASE_STUDENTS_TABLE=students
# VITE_SUPABASE_AVATARS_BUCKET=avatars
# VITE_SUPABASE_GALLERY_BUCKET=gallery
# VITE_SUPABASE_SCHEDULE_FILES_BUCKET=schedule-files
# VITE_SUPABASE_CALENDAR_FILES_BUCKET=calendar-files

# Optional non-Supabase API backend (used by chat endpoints if present)
# VITE_API_BASE_URL=http://localhost:1337
